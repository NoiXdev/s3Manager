    "@aws-sdk/lib-storage": "^3.1089.0",
    "@aws-sdk/s3-request-presigner": "^3.1089.0",
    "@tanstack/react-query": "^5.101.2",
    "electron-squirrel-startup": "^1.0.1",
    "i18next": "^26.3.6",
    "node-sqlite3-wasm": "^0.8.59",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.10",
    "react-icons": "^5.7.0",
    "tslib": "^2.8.1"
